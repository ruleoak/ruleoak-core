{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/agentic/ruleoak-manifest-v1.schema.json",
  "title": "RuleOak Manifest v1",
  "description": "Permissive protocol schema for .ruleoak.yml-compatible agent permission manifests.",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "project", "agent", "permissions", "evidence", "redaction"],
  "properties": {
    "version": { "const": "ruleoak.manifest.v1" },
    "project": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string", "minLength": 1 }, "description": { "type": "string" } } },
    "agent": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string", "minLength": 1 }, "runtime": { "type": "string" }, "description": { "type": "string" } } },
    "permissions": { "type": "object" },
    "tools": { "type": "array" },
    "approval": { "type": "object" },
    "evidence": { "type": "object", "required": ["enabled", "format"], "properties": { "enabled": { "type": "boolean" }, "format": { "const": "jsonl" }, "path": { "type": "string" }, "replayable": { "type": "boolean" } } },
    "redaction": { "type": "object", "required": ["enabled"], "properties": { "enabled": { "type": "boolean" }, "patterns": { "type": "array", "items": { "type": "string" } } } },
    "policyPacks": { "type": "array", "items": { "type": "string" } }
  }
}
