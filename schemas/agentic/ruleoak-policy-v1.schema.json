    "calendar": { "type": "object" },
    "mcp": { "type": "object" },
    "context": { "type": "object" },
    "evidence": { "type": "object" },
    "dryRun": { "type": "object" },
    "approval": { "type": "object" }
  },
  "additionalProperties": true
}
