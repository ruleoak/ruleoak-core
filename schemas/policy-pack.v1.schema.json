{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.dev/schemas/policy-pack.v1.schema.json",
  "title": "RuleOak Policy Pack Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "category",
    "description",
    "compatibility",
    "policy",
    "scenarioTests",
    "tools",
    "metadata"
  ],
  "properties": {
    "schemaVersion": { "const": "ruleoak.policy_pack.v1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" },
    "category": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "compatibility": {
      "type": "object",
      "additionalProperties": true,
      "required": ["policyPackSchema", "governanceProtocol", "latestPublicCoreRelease", "developmentTrack"],
      "properties": {
        "policyPackSchema": { "const": "ruleoak.policy_pack.v1" },
        "governanceProtocol": { "const": "ruleoak.governance.v1" },
        "latestPublicCoreRelease": { "const": "v2.2.0" },
        "earlierPublicBaseline": { "const": "v1.0.1" },
        "developmentTrack": { "type": "string", "minLength": 1 },
        "supportsCoreMajor": { "type": "array", "items": { "type": "string" } }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allowedTools": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "approvalRequired": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "blockedTools": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "boundary": { "type": "string" }
      }
    },
    "scenarioTests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "calls"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "calls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["toolId", "expectedDecision"],
              "properties": {
                "toolId": { "type": "string", "minLength": 1 },
                "subject": { "type": "string" },
                "expectedDecision": { "enum": ["allowed", "approval_required", "blocked"] }
              }
            }
          }
        }
      }
    },
    "tools": { "type": "array" },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
