{
  "schemaVersion": "ruleoak.policy_pack.v1",
  "id": "pii-redaction",
  "name": "PII Redaction Guard",
  "version": "1.0.0",
  "category": "privacy",
  "description": "Requires redaction before external processing and blocks raw PII export.",
  "compatibility": {
    "policyPackSchema": "ruleoak.policy_pack.v1",
    "governanceProtocol": "ruleoak.governance.v1",
    "latestPublicCoreRelease": "v2.2.0",
    "earlierPublicBaseline": "v1.0.1",
    "developmentTrack": "RuleOak Core v2.2.0 release",
    "supportsCoreMajor": [
      "2",
      "future-3"
    ]
  },
  "policy": {
    "allowedTools": [
      "detect_pii",
      "redact_pii",
      "process_redacted_text"
    ],
    "approvalRequired": [
      "export_redacted_summary"
    ],
    "blockedTools": [
      "export_raw_pii",
      "send_raw_pii_to_cloud"
    ],
    "boundary": "privacy_first"
  },
  "scenarioTests": [
    {
      "id": "pii-redaction-default-scenario",
      "title": "PII Redaction Guard default scenario",
      "description": "Pack-local scenario used by RuleOak Policy Pack Maturity checks. It evaluates declared allow, approval, and deny decisions without executing tools.",
      "calls": [
        {
          "toolId": "detect_pii",
          "subject": "pii-redaction scenario: detect_pii",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "redact_pii",
          "subject": "pii-redaction scenario: redact_pii",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "process_redacted_text",
          "subject": "pii-redaction scenario: process_redacted_text",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "export_redacted_summary",
          "subject": "pii-redaction scenario: export_redacted_summary",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "export_raw_pii",
          "subject": "pii-redaction scenario: export_raw_pii",
          "expectedDecision": "blocked"
        },
        {
          "toolId": "send_raw_pii_to_cloud",
          "subject": "pii-redaction scenario: send_raw_pii_to_cloud",
          "expectedDecision": "blocked"
        }
      ]
    }
  ],
  "tools": [],
  "metadata": {
    "maturity": "reference-pack",
    "owner": "RuleOak maintainers",
    "status": "public-release",
    "publicCoreBaseline": "v2.2.0"
  }
}
