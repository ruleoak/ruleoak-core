{
  "schemaVersion": "ruleoak.policy_pack.v1",
  "id": "filesystem-safe",
  "name": "Filesystem Safe Actions",
  "version": "1.0.0",
  "category": "filesystem",
  "description": "Local-first filesystem safety defaults: read/list allowed, writes approval-gated, destructive actions blocked.",
  "compatibility": {
    "policyPackSchema": "ruleoak.policy_pack.v1",
    "governanceProtocol": "ruleoak.governance.v1",
    "latestPublicCoreRelease": "v2.2.0",
    "earlierPublicBaseline": "v1.0.1",
    "developmentTrack": "RuleOak Core v2.2.0 release",
    "supportsCoreMajor": [
      "2",
      "future-3"
    ]
  },
  "policy": {
    "allowedTools": [
      "search_docs",
      "read_workspace_file",
      "list_workspace_files",
      "generate_report"
    ],
    "approvalRequired": [
      "write_workspace_file",
      "create_workspace_note"
    ],
    "blockedTools": [
      "delete_workspace_file",
      "modify_secret_file",
      "read_secret_file"
    ],
    "boundary": "local_only"
  },
  "scenarioTests": [
    {
      "id": "filesystem-safe-default-scenario",
      "title": "Filesystem Safe Actions default scenario",
      "description": "Pack-local scenario used by RuleOak Policy Pack Maturity checks. It evaluates declared allow, approval, and deny decisions without executing tools.",
      "calls": [
        {
          "toolId": "search_docs",
          "subject": "filesystem-safe scenario: search_docs",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "read_workspace_file",
          "subject": "filesystem-safe scenario: read_workspace_file",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "list_workspace_files",
          "subject": "filesystem-safe scenario: list_workspace_files",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "write_workspace_file",
          "subject": "filesystem-safe scenario: write_workspace_file",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "create_workspace_note",
          "subject": "filesystem-safe scenario: create_workspace_note",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "delete_workspace_file",
          "subject": "filesystem-safe scenario: delete_workspace_file",
          "expectedDecision": "blocked"
        },
        {
          "toolId": "modify_secret_file",
          "subject": "filesystem-safe scenario: modify_secret_file",
          "expectedDecision": "blocked"
        },
        {
          "toolId": "read_secret_file",
          "subject": "filesystem-safe scenario: read_secret_file",
          "expectedDecision": "blocked"
        }
      ]
    }
  ],
  "tools": [
    {
      "id": "search_docs",
      "risk": "low"
    },
    {
      "id": "delete_workspace_file",
      "risk": "critical"
    }
  ],
  "metadata": {
    "maturity": "reference-pack",
    "owner": "RuleOak maintainers",
    "status": "public-release",
    "publicCoreBaseline": "v2.2.0"
  }
}
