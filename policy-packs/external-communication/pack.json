{
  "schemaVersion": "ruleoak.policy_pack.v1",
  "id": "external-communication",
  "name": "External Communication Approval",
  "version": "1.0.0",
  "category": "communication",
  "description": "Requires human approval before sending external messages or publishing outside the local workspace.",
  "compatibility": {
    "policyPackSchema": "ruleoak.policy_pack.v1",
    "governanceProtocol": "ruleoak.governance.v1",
    "latestPublicCoreRelease": "v2.2.0",
    "earlierPublicBaseline": "v1.0.1",
    "developmentTrack": "RuleOak Core v2.2.0 release",
    "supportsCoreMajor": [
      "2",
      "future-3"
    ]
  },
  "policy": {
    "allowedTools": [
      "draft_external_message",
      "summarize_thread"
    ],
    "approvalRequired": [
      "send_external_message",
      "publish_external_update",
      "post_to_channel"
    ],
    "blockedTools": [
      "send_bulk_external_message"
    ],
    "boundary": "approval_required_for_external_actions"
  },
  "scenarioTests": [
    {
      "id": "external-communication-default-scenario",
      "title": "External Communication Approval default scenario",
      "description": "Pack-local scenario used by RuleOak Policy Pack Maturity checks. It evaluates declared allow, approval, and deny decisions without executing tools.",
      "calls": [
        {
          "toolId": "draft_external_message",
          "subject": "external-communication scenario: draft_external_message",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "summarize_thread",
          "subject": "external-communication scenario: summarize_thread",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "send_external_message",
          "subject": "external-communication scenario: send_external_message",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "publish_external_update",
          "subject": "external-communication scenario: publish_external_update",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "post_to_channel",
          "subject": "external-communication scenario: post_to_channel",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "send_bulk_external_message",
          "subject": "external-communication scenario: send_bulk_external_message",
          "expectedDecision": "blocked"
        }
      ]
    }
  ],
  "tools": [],
  "metadata": {
    "maturity": "reference-pack",
    "owner": "RuleOak maintainers",
    "status": "public-release",
    "publicCoreBaseline": "v2.2.0"
  }
}
