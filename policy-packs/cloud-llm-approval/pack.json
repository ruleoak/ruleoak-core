{
  "schemaVersion": "ruleoak.policy_pack.v1",
  "id": "cloud-llm-approval",
  "name": "Cloud LLM Approval",
  "version": "1.0.0",
  "category": "llm",
  "description": "Keeps local LLM calls allowed and requires approval before cloud LLM calls or external data transfer.",
  "compatibility": {
    "policyPackSchema": "ruleoak.policy_pack.v1",
    "governanceProtocol": "ruleoak.governance.v1",
    "latestPublicCoreRelease": "v2.2.0",
    "earlierPublicBaseline": "v1.0.1",
    "developmentTrack": "RuleOak Core v2.2.0 release",
    "supportsCoreMajor": [
      "2",
      "future-3"
    ]
  },
  "policy": {
    "allowedTools": [
      "local_llm_generate",
      "redact_prompt",
      "summarize_locally"
    ],
    "approvalRequired": [
      "cloud_llm_generate",
      "send_prompt_to_cloud"
    ],
    "blockedTools": [
      "upload_raw_data_to_cloud",
      "send_secret_to_llm"
    ],
    "boundary": "local_first_cloud_approval"
  },
  "scenarioTests": [
    {
      "id": "cloud-llm-approval-default-scenario",
      "title": "Cloud LLM Approval default scenario",
      "description": "Pack-local scenario used by RuleOak Policy Pack Maturity checks. It evaluates declared allow, approval, and deny decisions without executing tools.",
      "calls": [
        {
          "toolId": "local_llm_generate",
          "subject": "cloud-llm-approval scenario: local_llm_generate",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "redact_prompt",
          "subject": "cloud-llm-approval scenario: redact_prompt",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "summarize_locally",
          "subject": "cloud-llm-approval scenario: summarize_locally",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "cloud_llm_generate",
          "subject": "cloud-llm-approval scenario: cloud_llm_generate",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "send_prompt_to_cloud",
          "subject": "cloud-llm-approval scenario: send_prompt_to_cloud",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "upload_raw_data_to_cloud",
          "subject": "cloud-llm-approval scenario: upload_raw_data_to_cloud",
          "expectedDecision": "blocked"
        },
        {
          "toolId": "send_secret_to_llm",
          "subject": "cloud-llm-approval scenario: send_secret_to_llm",
          "expectedDecision": "blocked"
        }
      ]
    }
  ],
  "tools": [],
  "metadata": {
    "maturity": "reference-pack",
    "owner": "RuleOak maintainers",
    "status": "public-release",
    "publicCoreBaseline": "v2.2.0"
  }
}
