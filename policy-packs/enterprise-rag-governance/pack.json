{
  "schemaVersion": "ruleoak.policy_pack.v1",
  "id": "enterprise-rag-governance",
  "name": "Enterprise RAG Answer Governance",
  "version": "1.0.0",
  "category": "rag",
  "description": "Govern enterprise RAG search, restricted-document use, citations, and unsupported answer blocking.",
  "compatibility": {
    "policyPackSchema": "ruleoak.policy_pack.v1",
    "governanceProtocol": "ruleoak.governance.v1",
    "latestPublicCoreRelease": "v2.2.0",
    "earlierPublicBaseline": "v1.0.1",
    "developmentTrack": "RuleOak Core v2.2.0 release",
    "supportsCoreMajor": [
      "2",
      "future-3"
    ]
  },
  "policy": {
    "boundary": "evidence_required_rag_answer_boundary",
    "allowedTools": [
      "read.user_question",
      "read.corpus_manifest",
      "search.knowledge_base",
      "read.policy_doc",
      "check.citation_coverage",
      "scan.redaction",
      "generate.cited_answer",
      "generate.audit_report"
    ],
    "approvalRequired": [
      "read.restricted_document",
      "export.answer_bundle",
      "send.external_answer"
    ],
    "blockedTools": [
      "answer.without_evidence",
      "reveal.redacted_pii",
      "cite.unapproved_source"
    ]
  },
  "scenarioTests": [
    {
      "id": "enterprise-rag-governance-default-scenario",
      "title": "Enterprise RAG Answer Governance default scenario",
      "description": "Pack-local scenario used by RuleOak Policy Pack Maturity checks. It evaluates declared allow, approval, and deny decisions without executing tools.",
      "calls": [
        {
          "toolId": "read.user_question",
          "subject": "enterprise-rag-governance scenario: read.user_question",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "read.corpus_manifest",
          "subject": "enterprise-rag-governance scenario: read.corpus_manifest",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "search.knowledge_base",
          "subject": "enterprise-rag-governance scenario: search.knowledge_base",
          "expectedDecision": "allowed"
        },
        {
          "toolId": "read.restricted_document",
          "subject": "enterprise-rag-governance scenario: read.restricted_document",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "export.answer_bundle",
          "subject": "enterprise-rag-governance scenario: export.answer_bundle",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "send.external_answer",
          "subject": "enterprise-rag-governance scenario: send.external_answer",
          "expectedDecision": "approval_required"
        },
        {
          "toolId": "answer.without_evidence",
          "subject": "enterprise-rag-governance scenario: answer.without_evidence",
          "expectedDecision": "blocked"
        },
        {
          "toolId": "reveal.redacted_pii",
          "subject": "enterprise-rag-governance scenario: reveal.redacted_pii",
          "expectedDecision": "blocked"
        },
        {
          "toolId": "cite.unapproved_source",
          "subject": "enterprise-rag-governance scenario: cite.unapproved_source",
          "expectedDecision": "blocked"
        }
      ]
    }
  ],
  "tools": [
    {
      "id": "read.user_question",
      "risk": "low"
    },
    {
      "id": "read.corpus_manifest",
      "risk": "low"
    },
    {
      "id": "search.knowledge_base",
      "risk": "low"
    },
    {
      "id": "read.restricted_document",
      "risk": "high"
    },
    {
      "id": "export.answer_bundle",
      "risk": "high"
    },
    {
      "id": "answer.without_evidence",
      "risk": "critical"
    },
    {
      "id": "reveal.redacted_pii",
      "risk": "critical"
    }
  ],
