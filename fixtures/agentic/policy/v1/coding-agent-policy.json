{
  "schemaVersion": "ruleoak.policy.v1",
  "defaultAction": "approval",
  "tools": {
    "filesystem.read": "allow",
    "filesystem.write": "approval",
    "shell.run": "approval",
    "git.destructive": "approval",
    "secret.read": "deny"
  },
  "paths": { "workspaceOnly": true, "deny": [".env", ".ssh", ".git"] },
  "evidence": { "capture": "summary", "redactSecrets": true }
}
