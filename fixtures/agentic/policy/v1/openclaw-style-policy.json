{
  "schemaVersion": "ruleoak.policy.v1",
  "defaultAction": "approval",
  "tools": {
    "filesystem.read": "allow",
    "filesystem.write": "approval",
    "filesystem.delete": "approval",
    "shell.run": "deny",
    "database.query": "allow",
    "database.mutate": "approval",
    "email.send": "approval",
    "skill.install": "approval"
  },
  "evidence": { "capture": "summary", "redactSecrets": true },
  "dryRun": { "requiredFor": ["filesystem.write", "filesystem.delete", "database.mutate", "email.send"] },
  "approval": { "expiresInMinutes": 30 }
}
