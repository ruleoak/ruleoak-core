{
  "demo": "research-brief-demo",
  "version": "1.0.0",
  "allowed_actions": [
    "source.read",
    "claim.extract",
    "claim.score",
    "brief.draft",
    "brief.export"
  ],
  "approval_required": [
    "brief.publish",
    "external.email.send",
    "decision.finalize"
  ],
  "blocked_actions": [
    "citation.fabricate",
    "claim.unsourced",
    "source.overquote",
    "personal_data.infer"
  ],
  "evidence_rules": {
    "every_claim_requires_source_id": true,
    "unsupported_claim_confidence": "low",
    "max_direct_quote_words_per_source": 25
  },
  "output_rules": {
    "must_show_unknowns": true,
    "must_separate_facts_from_recommendations": true,
    "must_include_approval_boundary": true
  }
}
