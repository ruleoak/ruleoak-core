{
  "id": "technical-consultant-demo",
  "name": "Technical Consultant Demo",
  "boundary": "local_only",
  "allowedTools": [
    "case.read",
    "logs.read",
    "metrics.read",
    "notes.read",
    "report.write"
  ],
  "blockedTools": [
    "production.change",
    "case.close",
    "customer.notify"
