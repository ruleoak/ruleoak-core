{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruleoak.com/schemas/agentic/evidence-event-v1.schema.json",
  "title": "RuleOak Evidence Event v1",
  "description": "Permissive protocol schema for RuleOak-compatible agent action evidence JSONL.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "eventId", "runId", "sessionId", "sequence", "type", "timestamp", "actor", "payload"],
  "properties": {
    "schemaVersion": { "const": "ruleoak.agentic.evidence.v1" },
    "eventId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 0 },
    "type": {
      "type": "string",
      "enum": ["run_started", "action_requested", "policy_decision", "approval_requested", "approval_decision", "action_executed", "action_failed", "run_finished", "tool_inventory", "tool_filter_decision", "dry_run_preview", "incident_report_generated", "vault_indexed", "trust_score_generated"]
    },
    "timestamp": { "type": "string" },
    "actor": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" }
  }
}
